{
  "name": "vocab-system",
  "version": "1.0.0",
  "description": "一个基于纯前端技术（HTML/CSS/JavaScript）的在线英语单词智能学习与语境检测系统，专为初中英语教育设计。",
  "main": "server/server.js",
  "scripts": {
    "build": "prisma generate",
    "vercel-build": "prisma generate && prisma db push --accept-data-loss",
    "start": "node backend/src/server.js",
    "start:legacy": "node server/server.js",
    "start:vercel-local": "vercel dev",
    "postinstall": "prisma generate",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "reset:admin": "node backend/scripts/reset-admin-password.js",
    "reset:admin:legacy": "node backend/scripts/reset-admin-password.js --mode=legacy",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newsunlee007/vocab-system.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/newsunlee007/vocab-system/issues"
  },
  "homepage": "https://github.com/newsunlee007/vocab-system#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.1",
    "morgan": "^1.10.1",
    "nedb-promises": "^6.2.3",
    "@prisma/client": "^6.4.1",
    "prisma": "^6.4.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "supertest": "^7.1.4",
    "vercel": "^39.4.2"
  }
}
