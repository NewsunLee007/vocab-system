{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/auth/:action",
      "destination": "/api/auth/index"
    },
    {
      "source": "/api/learning-records",
      "destination": "/api/learning-records/index"
    },
    {
      "source": "/api/word-lists",
      "destination": "/api/word-lists/index"
    },
    {
      "source": "/api/word-lists/(?<id>[^/]+)",
      "destination": "/api/word-lists/index?id=$id"
    },
    {
      "source": "/api/students/(?<id>[^/]+)",
      "destination": "/api/students/[id]?id=$id"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
